# Copy to .env.local for Vercel CLI, or set in Vercel → Project → Settings → Environment Variables.
# Never commit real values. Rotate keys if they were ever exposed in chat or git.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_JWT_SECRET=long_random_string

# Optional: comma-separated origins, or * for mobile/web dev
CORS_ORIGINS=*
